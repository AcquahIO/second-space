{
  "name": "second-space",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "npm run build --workspace=@second-space/shared-types && npm run build --workspace=@second-space/sim-engine && npm run build --workspace=@second-space/tool-adapters && npm run build --workspace=@second-space/worker && npm run build --workspace=@second-space/web",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose -f infra/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker-compose.yml down -v"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^22.10.2",
    "bcryptjs": "^2.4.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
